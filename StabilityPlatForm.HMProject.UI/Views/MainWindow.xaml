<Window
    x:Class="StabilityPlatForm.HMProject.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:StabilityPlatForm.HMProject.UI.Views"
    Title="HM Lab"
    Width="1920"
    Height="1080"
    Closing="Window_Closing"
    Icon="/Images/Exe_picture1.png"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="#F0F4F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Panel.ZIndex="10">
            <Border Background="White">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="8"
                        Direction="270"
                        Opacity="0.05"
                        ShadowDepth="2"
                        Color="#000000" />
                </Border.Effect>
            </Border>
            <Border
                Padding="25,0"
                Background="White"
                RenderOptions.ClearTypeHint="Enabled">
                <DockPanel VerticalAlignment="Center">
                    <Image
                        Width="45"
                        Height="45"
                        Margin="0,0,15,0"
                        DockPanel.Dock="Left"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="/Images/HM Lab.png"
                        Stretch="Uniform" />
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#1A1A1A"
                        Text="HM Lab Stability Testing Platform" />
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,1,0,0">
                <Border Background="White">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Direction="0"
                            Opacity="0.05"
                            ShadowDepth="3"
                            Color="#000000" />
                    </Border.Effect>
                </Border>
                <Border Background="White" RenderOptions.ClearTypeHint="Enabled">
                    <StackPanel Margin="0,20,0,0">
                        <RadioButton
                            x:Name="MenuStabilityTest"
                            Content="Stability Testing"
                            GroupName="SidebarMenu"
                            IsChecked="True"
                            Style="{StaticResource SidebarMenuItemStyle}" />

                        <RadioButton
                            x:Name="MenuDeviceStatus"
                            Content="Device Status"
                            GroupName="SidebarMenu"
                            Style="{StaticResource SidebarMenuItemStyle}" />

                        <RadioButton
                            x:Name="MenuStabilityPrediction"
                            Content="Stability Prediction"
                            GroupName="SidebarMenu"
                            Style="{StaticResource SidebarMenuItemStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="20,20,20,20">

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=MenuStabilityTest}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <TabControl
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="CavityName"
                        ItemsSource="{Binding Cavitys}"
                        SelectedItem="{Binding SelectedCavity}"
                        Style="{StaticResource ModernTabControlStyle}">
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <views:CavityView />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=MenuDeviceStatus}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <TabControl
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="CavityName"
                        ItemsSource="{Binding Cavitys}"
                        SelectedItem="{Binding SelectedCavity}"
                        Style="{StaticResource ModernTabControlStyle}">
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <views:DeviceStatusView DataContext="{Binding DeviceStatusVM}"/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=MenuStabilityPrediction}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <views:PredictionView />
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>