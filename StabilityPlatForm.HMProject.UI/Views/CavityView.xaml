<UserControl
    x:Class="StabilityPlatForm.HMProject.UI.Views.CavityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="850"
    d:DesignWidth="1400"
    mc:Ignorable="d">

    <Grid Margin="0,10,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Opacity="0.05"
                        ShadowDepth="5"
                        Color="#000000" />
                </Border.Effect>
            </Border>
            <Border
                Padding="30"
                Background="White"
                CornerRadius="12"
                RenderOptions.ClearTypeHint="Enabled">
                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top">

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Opacity" Value="0.6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                <Button
                                    Width="80"
                                    Height="34"
                                    Background="#1E293B"
                                    Command="{Binding SelectPathCommand}"
                                    Content="Path"
                                    Cursor="Hand"
                                    FontWeight="Bold"
                                    Foreground="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Text="{TemplateBinding Content}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock
                                    MaxWidth="280"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{Binding PathColor}"
                                    Text="{Binding SavePath}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="File Name" />
                            <TextBox
                                Foreground="{Binding PathColor}"
                                IsReadOnly="True"
                                Text="{Binding FileName}" />
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Device Type" />
                                <StackPanel
                                    Height="38"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <RadioButton
                                        Margin="0,0,15,0"
                                        Content="N-I-P"
                                        GroupName="{Binding CavityName, StringFormat={}{0}_Type}"
                                        IsChecked="{Binding IsFormalType}"
                                        Style="{StaticResource ModernRadioButtonStyle}" />

                                    <RadioButton
                                        Content="P-I-N"
                                        GroupName="{Binding CavityName, StringFormat={}{0}_Type}"
                                        IsChecked="{Binding IsInvertedType}"
                                        Style="{StaticResource ModernRadioButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Area (cm²)" />
                                <TextBox Text="{Binding DeviceArea}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Initial Voltage (V)" />
                                <TextBox Text="{Binding InitialVoltage, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Terminal Voltage (V)" />
                                <TextBox Text="{Binding TerminalVoltage, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Voltage Step (V)" />
                                <TextBox Text="{Binding VoltageStep, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Applied Bias (V)" />
                                <TextBox Text="{Binding AppliedVoltage, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Test Mode" />
                                <ComboBox ItemsSource="{Binding AvailableTestModes}" SelectedItem="{Binding SelectedTestMode}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource TopLabelStyle}" Text="Resume Time (h)" />
                                <TextBox Text="{Binding ResumedTimeHours, UpdateSourceTrigger=PropertyChanged}" ToolTip="输入断电前的运行时间(小时)，如果是全新测试请保持为0" />
                            </StackPanel>
                        </Grid>

                        <ContentControl IsEnabled="{Binding HasTestMode}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="Content" Value="Select test mode above to set conditions..." />
                                    <Setter Property="Foreground" Value="#AAAAAA" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-LC-1/2">
                                            <Setter Property="Content" Value="{Binding}" />
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="20" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="Light Time (h)" />
                                                                    <TextBox Text="{Binding SunTime}" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="Dark Time (h)" />
                                                                    <TextBox Text="{Binding DarkTime}" />
                                                                </StackPanel>
                                                            </Grid>
                                                            <TextBlock
                                                                Margin="0,5,0,0"
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="#107C10"
                                                                Text="* Room Temp Default" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-L-1">
                                            <Setter Property="Content" Value="{Binding}" />
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Style="{StaticResource TopLabelStyle}" Text="Target Temperature (℃)" />
                                                            <TextBox Text="{Binding TargetTemperature}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding SelectedTestMode}" Value="ISOS-L-2">
                                            <Setter Property="Content" Value="{Binding}" />
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,20">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="20" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="Low Temp (℃)" />
                                                                    <TextBox Text="{Binding CycleLowTemperature}" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="High Temp (℃)" />
                                                                    <TextBox Text="{Binding CycleHighTemperature}" />
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="20" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="Heat Time (h)" />
                                                                    <TextBox Text="{Binding HeatingTime}" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Style="{StaticResource TopLabelStyle}" Text="Cool Time (h)" />
                                                                    <TextBox Text="{Binding CoolingTime}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </StackPanel>

                    <Button
                        Height="48"
                        Margin="0,35,0,0"
                        BorderThickness="0"
                        Command="{Binding StartTestCommand}"
                        Cursor="Hand"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0.0" Color="Green" />
                                <GradientStop Offset="1.0" Color="LightGreen" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="startBtnBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            x:Name="startBtnTxt"
                                            VerticalAlignment="Center"
                                            Text="Start Testing" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="startBtnBorder" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0.0" Color="DarkGreen" />
                                                    <GradientStop Offset="1.0" Color="MediumSeaGreen" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="startBtnBorder" Property="Background" Value="#E2E8F0" />
                                        <Setter TargetName="startBtnTxt" Property="Foreground" Value="#94A3B8" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Border Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="5" Color="#000000" />
                </Border.Effect>
            </Border>

            <Border Padding="25" Background="White" CornerRadius="12" RenderOptions.ClearTypeHint="Enabled">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Style="{StaticResource TestingPanelStyle}">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <ContentControl Grid.Column="0" Height="85" Padding="15,10" Style="{StaticResource DataCardStyle}">
                                <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" Foreground="#888888" Text="Temperature" />
                                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Bottom" FontSize="30" FontWeight="Bold" Foreground="#FF5722" Text="{Binding CurrentTemperature, StringFormat={}{0:F1}}" />
                                        <TextBlock Margin="3,0,0,5" VerticalAlignment="Bottom" FontSize="16" FontWeight="Bold" Foreground="#A0A0A0" Text="℃" />
                                    </StackPanel>
                                </Grid>
                            </ContentControl>

                            <ContentControl Grid.Column="2" Height="85" Padding="15,10" Style="{StaticResource DataCardStyle}">
                                <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" Foreground="#888888" Text="Operating Time" />
                                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Bottom" FontSize="30" FontWeight="Bold" Foreground="#007BFF" Text="{Binding RunningTime, StringFormat={}{0:hh\\:mm\\:ss}}" />
                                    </StackPanel>
                                </Grid>
                            </ContentControl>

                            <ContentControl Grid.Column="4" Height="85" Padding="15,10" Style="{StaticResource DataCardStyle}">
                                <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" Foreground="#888888" Text="T80 Alert Status" />
                                    <StackPanel Grid.Row="1" Margin="0,0,0,4" VerticalAlignment="Bottom" Orientation="Horizontal">
                                        <Ellipse Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{Binding T80WarningColor}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#333333" Text="{Binding T80StatusText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </ContentControl>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ContentControl Grid.Column="0" Margin="0,0,15,0" Padding="15" Style="{StaticResource DataCardStyle}">
                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Margin="0,0,0,10" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#444444" Text="Device Selection" TextAlignment="Center" />

                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">

                                    <Border Margin="0,0,15,0" Padding="10" Background="LightBlue" CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,5" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#0066FF" Text="Left Block" />
                                            <UniformGrid Columns="3" Rows="3">
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 1" Content="1" GroupName="{Binding CavityName}" IsChecked="True" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 2" Content="2" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 3" Content="3" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 4" Content="4" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 5" Content="5" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 6" Content="6" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 7" Content="7" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 8" Content="8" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Left - Device 9" Content="9" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="10" Background="LightBlue" CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,5" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#0066FF" Text="Right Block" />
                                            <UniformGrid Columns="3" Rows="3">
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 1" Content="1" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 2" Content="2" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 3" Content="3" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 4" Content="4" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 5" Content="5" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 6" Content="6" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 7" Content="7" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 8" Content="8" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                                <RadioButton Command="{Binding SelectDeviceCommand}" CommandParameter="Right - Device 9" Content="9" GroupName="{Binding CavityName}" Style="{StaticResource DeviceToggleStyle}" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Row="2" Style="{StaticResource TestingPanelStyle}">
                                    <Button Width="140" Height="45" Margin="0,20,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding StopTestCommand}" Content="Stop testing" Style="{StaticResource DangerButtonStyle}" />
                                </Grid>
                            </Grid>
                        </ContentControl>

                        <Grid Grid.Column="1">
                            <Grid Style="{StaticResource IdlePanelStyle}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Margin="0,0,0,20" HorizontalAlignment="Center" FontSize="80" Foreground="#E0E0E0" Text="📈" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="#B0B0B0" Text="请在左侧矩阵中打勾启用需要测试的器件" />
                                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="14" Foreground="#C0C0C0" Text="参数配置完毕后点击 Start Testing 开始测试" />
                                </StackPanel>
                            </Grid>

                            <Grid Style="{StaticResource TestingPanelStyle}">
                                <ContentControl Padding="20" Style="{StaticResource GraphPlaceholderStyle}">
                                    <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Margin="0,0,0,15" VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#444444" Text="PCE-Time Graph: " />
                                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#007BFF" Text="{Binding ChartDisplayTitle}" />
                                        </StackPanel>

                                        <lvc:CartesianChart Grid.Row="1" Series="{Binding PceSeries}" TooltipPosition="Hidden" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" ZoomMode="X" />
                                    </Grid>
                                </ContentControl>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2" Style="{StaticResource TestingPanelStyle}">
                        <ContentControl Height="140" Margin="0,15,0,0" Padding="15" Style="{StaticResource DataCardStyle}">
                            <Grid Background="White" RenderOptions.ClearTypeHint="Enabled">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal">
                                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#007BFF" Text="&#xE81C;" />
                                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#444444" Text="Testing Logs" />
                                </StackPanel>
                                <ListBox x:Name="LogListBox" Grid.Row="1" Padding="8" Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" FontFamily="Consolas" FontSize="13" Foreground="#334155" ItemsSource="{Binding TestLogs}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2" Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Focusable" Value="False" />
                                            <Setter Property="IsHitTestVisible" Value="False" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Padding="0,2">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </ContentControl>
                    </Grid>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>