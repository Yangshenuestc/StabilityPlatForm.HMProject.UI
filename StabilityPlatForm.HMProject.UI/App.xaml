<Application
    x:Class="StabilityPlatForm.HMProject.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:StabilityPlatForm.HMProject.UI"
    xmlns:conv="clr-namespace:StabilityPlatForm.HMProject.UI.Converters">
    <Application.Resources>

        <conv:T80BadgeVisibilityConverter x:Key="T80BadgeConverter" />
        <conv:DeviceEnabledBoolConverter x:Key="DeviceEnabledConverter" />

        <Style x:Key="TopLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7A8599" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SidebarMenuItemStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="10,5,10,5" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="sidebarBorder"
                            Padding="20,0"
                            Background="Transparent"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="sidebarBorder" Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="sidebarBorder" Property="Background" Value="#E6F0FF" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="#F8FAFC"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0066FF" />
                                <Setter Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="OrangeRed" />
                        <GradientStop Offset="1.0" Color="Orange" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="dangerBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="dangerBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0.0" Color="DarkRed" />
                                            <GradientStop Offset="1.0" Color="Red" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataCardStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="12"
                                        Opacity="0.04"
                                        ShadowDepth="4"
                                        Color="#000000" />
                                </Border.Effect>
                            </Border>
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12"
                                RenderOptions.ClearTypeHint="Enabled">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GraphPlaceholderStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid>
                            <Border
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="15"
                                        Opacity="0.06"
                                        ShadowDepth="5"
                                        Color="#000000" />
                                </Border.Effect>
                            </Border>
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="White"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1"
                                CornerRadius="12"
                                RenderOptions.ClearTypeHint="Enabled">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="25,15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="Border"
                            Margin="5,0"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderThickness="0,0,0,3">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0066FF" />
                                <Setter Property="Foreground" Value="#0066FF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="Foreground" Value="#444444" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="TabHeaderArea"
                                Grid.Row="0"
                                Padding="15,0"
                                Background="Transparent">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernTabItemStyle}" />
        </Style>

        <Style x:Key="ModernRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,30,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Grid Width="18" Height="18">
                                    <Ellipse
                                        x:Name="BorderEllipse"
                                        Fill="White"
                                        Stroke="#B0B0B0"
                                        StrokeThickness="1.5" />
                                    <Ellipse
                                        x:Name="CheckEllipse"
                                        Width="10"
                                        Height="10"
                                        Fill="#0066FF"
                                        Visibility="Collapsed" />
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BorderEllipse" Property="Stroke" Value="#0066FF" />
                                <Setter TargetName="CheckEllipse" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderEllipse" Property="Stroke" Value="#0066FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PointButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse
                                x:Name="bg"
                                Fill="{TemplateBinding Background}"
                                Stroke="#CBD5E1"
                                StrokeThickness="1" />
                            <TextBlock
                                x:Name="txt"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Content}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceToggleStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Width" Value="66" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border
                                x:Name="deviceBorder"
                                Background="#F4F5F7"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.1" ShadowDepth="1" Color="#000000" />
                                </Border.Effect>
                                <Grid>
                                    <TextBlock
                                        x:Name="txt"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        FontWeight="Medium"
                                        Foreground="#334155"
                                        Text="{TemplateBinding Content}" />

                                    <UniformGrid
                                        x:Name="pointsGrid"
                                        Margin="2,20,2,2"
                                        Columns="2"
                                        Rows="3"
                                        Visibility="Collapsed">
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="1" Content="1">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="1">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="4" Content="4">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="4">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="2" Content="2">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="2">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="5" Content="5">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="5">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="3" Content="3">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="3">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Command="{Binding SelectPointCommand}" CommandParameter="6" Content="6">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource PointButtonStyle}" TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPointIndex}" Value="6">
                                                            <Setter Property="Background" Value="#1890FF" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                            <Border Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-8,0" Background="#E53935" CornerRadius="10" BorderBrush="White" BorderThickness="2" ToolTip="警告：该器件已发生 T80 衰减！">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource T80BadgeConverter}">
                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="DataContext.DeviceT80States" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </Border.Visibility>
                                <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>

                            <Button 
                                x:Name="configClicker"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DataContext.ToggleDeviceEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource TemplatedParent}}" />

                        </Grid>

                        <ControlTemplate.Triggers>

                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource DeviceEnabledConverter}">
                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}" />
                                        <Binding Path="DataContext.DeviceEnabledDict" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="deviceBorder" Property="Background" Value="#ED7D31" />
                                <Setter TargetName="txt" Property="Foreground" Value="White" />
                            </DataTrigger>

                            <DataTrigger Value="False">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource DeviceEnabledConverter}">
                                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}" />
                                        <Binding Path="DataContext.DeviceEnabledDict" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter TargetName="deviceBorder" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="txt" Property="Foreground" Value="#94A3B8" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsTesting}" Value="True">
                                <Setter TargetName="configClicker" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="deviceBorder" Property="BorderBrush" Value="#0066FF" />
                                <Setter TargetName="deviceBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="txt" Property="FontWeight" Value="Bold" />
                            </Trigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsTesting}" Value="True" />
                                    <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="pointsGrid" Property="Visibility" Value="Visible" />
                                <Setter TargetName="txt" Property="VerticalAlignment" Value="Top" />
                                <Setter TargetName="txt" Property="Margin" Value="0,2,0,0" />
                                <Setter TargetName="txt" Property="FontSize" Value="13" />
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsTesting}" Value="True" />
                                    <Condition Value="False">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource DeviceEnabledConverter}">
                                                <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}" />
                                                <Binding Path="DataContext.DeviceEnabledDict" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter TargetName="deviceBorder" Property="BorderThickness" Value="0" />
                            </MultiDataTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="deviceBorder" Property="Opacity" Value="0.8" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IdlePanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TestingPanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTesting}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>